# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=podwires_community
DB_USER=podwires
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_VIP=price_vip_monthly_id

# WordPress API (Podwires.com)
WP_API_URL=https://podwires.com/wp-json/wp/v2
WP_API_KEY=your_wp_application_password

# WordPress SSO (must match WP_SSO_SECRET in wp-config.php)
WP_SSO_SECRET=your_shared_sso_secret_here

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:3000
